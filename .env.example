# ===== PostgreSQL =====
POSTGRES_USER=ctb
POSTGRES_PASSWORD=ctb_secret
POSTGRES_DB=crypto_bot

# ===== Backend =====
# Khi chạy bằng docker-compose, host là "postgres". Khi chạy local, dùng "localhost".
DATABASE_URL=postgresql://ctb:ctb_secret@localhost:5432/crypto_bot?schema=public
PORT=4000
NODE_ENV=development
JWT_SECRET=change_me_in_production

# ===== Binance =====
# Lấy từ https://www.binance.com (hoặc testnet https://testnet.binancefuture.com)
BINANCE_API_KEY=
BINANCE_API_SECRET=
# true = dùng Futures Testnet (KHUYẾN NGHỊ khi test). false = tài khoản thật.
BINANCE_TESTNET=true

# ===== Scanner =====
SCAN_INTERVAL_MS=60000

# ===== Frontend (build-time) =====
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000
