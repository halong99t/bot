  "description": "Crypto Trading Bot backend - Binance Futures scanner & LONG pattern auto-trader",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
